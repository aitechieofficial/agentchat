LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-local-proxy-key
LITELLM_PROXY_MODE=true
DEMO_MODE=false

# These should match the model aliases in your LiteLLM proxy config.
AGENT_1_NAME=Planner
AGENT_1_ROLE=Systems thinker
AGENT_1_MODEL=qwen
AGENT_1_COLOR=#f59e0b

AGENT_2_NAME=Facilitator
AGENT_2_ROLE=Moderator
AGENT_2_MODEL=gpt
AGENT_2_COLOR=#22c55e

AGENT_3_NAME=Challenger
AGENT_3_ROLE=Risk analyst
AGENT_3_MODEL=grok
AGENT_3_COLOR=#38bdf8

AGENT_4_NAME=Steward
AGENT_4_ROLE=Human impact reviewer
AGENT_4_MODEL=claude
AGENT_4_COLOR=#a78bfa
